    "demo": "bun examples/demo.ts",
    "check": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.6.0",
    "canonicalize": "^2.0.0",
    "multiformats": "^13.3.0",
